{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A T-shirt product in the store",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the T-shirt"
        },
        "price": {
          "type": "number",
          "description": "Price in USD"
        },
        "category": {
          "type": "string",
          "enum": ["Men", "Women", "Oversized"],
          "description": "Product category"
        },
        "description": {
          "type": "string",
          "description": "Detailed product description"
        },
        "imageUrl": {
          "type": "string",
          "description": "URL of the product image"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the product was added"
        }
      },
      "required": ["name", "price", "category", "description", "imageUrl", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "customerDetails": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" }
          },
          "required": ["name", "email", "phone", "address"]
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerDetails", "items", "totalAmount", "status", "createdAt"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Collection of T-shirt products"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders"
    }
  }
}
